rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each signed-in user can read/write only their own library
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Shared app config (e.g. the TMDB key): readable by any signed-in
    // user, writable by nobody from the client. Edit it in the Firebase
    // console (or Admin SDK) only.
    match /config/app {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Everything else: denied
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
